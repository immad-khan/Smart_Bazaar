    // 5. Search Logic for HomeShopping (Fast HttpClient)
    public async Task<List<ScrapedProduct>> SearchHomeShopping(string keyword)
    {
        try
        {
            string searchUrl = $"https://www.homeshopping.pk/categories/search/?product_name={Uri.EscapeDataString(keyword)}";
            var request = new HttpRequestMessage(HttpMethod.Get, searchUrl);
            request.Headers.Add("User-Agent", GetRandomUserAgent());

            var response = await _httpClient.SendAsync(request);
            if (!response.IsSuccessStatusCode) return new List<ScrapedProduct>();

            var html = await response.Content.ReadAsStringAsync();
            var doc = new HtmlDocument();
            doc.LoadHtml(html);

            var nodes = doc.DocumentNode.SelectNodes("//div[@class='product-layout']");
            var results = new List<ScrapedProduct>();

            if (nodes != null)
            {
                foreach (var node in nodes.Take(10))
                {
                    var name = node.SelectSingleNode(".//div[@class='name']//a")?.InnerText.Trim();
                    var price = node.SelectSingleNode(".//span[@class='price-new']")?.InnerText.Trim();
                    if (string.IsNullOrEmpty(price))
                        price = node.SelectSingleNode(".//p[@class='price']")?.InnerText.Trim();
                    
                    var link = node.SelectSingleNode(".//div[@class='name']//a")?.GetAttributeValue("href", "");
                    var image = node.SelectSingleNode(".//img")?.GetAttributeValue("src", "");

                    if (!string.IsNullOrEmpty(name) && !string.IsNullOrEmpty(price))
                    {
                        results.Add(new ScrapedProduct {
                            Name = System.Net.WebUtility.HtmlDecode(name),
                            Price = price,
                            Source = "HomeShopping",
                            Link = link ?? "",
                            Image = image ?? ""
                        });
                    }
                }
            }
            return results;
        }
        catch { return new List<ScrapedProduct>(); }
    }

    // 6. Combine Everything - Search All Pakistani Stores
    public async Task<List<ScrapedProduct>> SearchAllStores(string query)
    {
        // Run working scrapers in parallel
        var naheedTask = SearchNaheed(query);
        var bbabyTask = SearchBBabyBySuleman(query);
        var dinersTask = SearchDiners(query);
        var darazTask = SearchDaraz(query);

        await Task.WhenAll(naheedTask, bbabyTask, dinersTask, darazTask);

        var allResults = new List<ScrapedProduct>();
        allResults.AddRange(await naheedTask);
        allResults.AddRange(await bbabyTask);
        allResults.AddRange(await dinersTask);
        allResults.AddRange(await darazTask);

        return allResults;
    }

    private string GetRandomUserAgent() => _userAgents[new Random().Next(_userAgents.Count)];
}